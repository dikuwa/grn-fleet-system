# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth
BETTER_AUTH_SECRET=generate-32-random-bytes-here
BETTER_AUTH_URL=http://localhost:3000

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GovFleet Namibia

# Cloudflare R2 (Private object storage)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=govfleet-private
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=GovFleet <noreply@example.gov.na>

# Google Maps
GOOGLE_MAPS_SERVER_API_KEY=your-server-api-key
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=your-browser-api-key

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Background Jobs (Inngest)
INNGEST_EVENT_KEY=your-event-key
INNGEST_SIGNING_KEY=your-signing-key

# Monitoring (Sentry)
SENTRY_DSN=https://key@o1.ingest.sentry.io/project
SENTRY_AUTH_TOKEN=your-auth-token
SENTRY_ORG=govfleet
SENTRY_PROJECT=govfleet-namibia

# Security
SHARE_TOKEN_PEPPER=generate-32-random-bytes-here
DOCUMENT_HASH_SECRET=generate-independently
AUDIT_CHAIN_SECRET=generate-independently

# SMS Provider (Twilio)
# To enable SMS notifications, set ENABLE_SMS=true and choose a provider.
# Currently supported: twilio, vonage
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# SMS Provider (Vonage/Nexmo — alternative to Twilio)
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret
VONAGE_FROM_NUMBER=GovFleet

# Feature Flags
NEXT_PUBLIC_ENABLE_OFFLINE_DRAFTS=true
ENABLE_EXTERNAL_SHARING=true
ENABLE_WHATSAPP_API=false
ENABLE_SMS=false
SMS_PROVIDER=disabled

# Local Seed (development only)
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_PASSWORD=dev-seed-password-change-me
